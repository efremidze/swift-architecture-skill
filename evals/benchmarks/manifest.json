    {
      "id": "mvvm-stale-overwrite-good",
      "architecture": "mvvm",
      "file": "evals/benchmarks/cases/mvvm-stale-overwrite-good.md",
      "expect_syntax": true,
      "expect_semantic": true,
      "expect_architecture": true,
      "architecture_assertions": [
        {
          "label": "Triggers two sequential loads for stale overwrite scenario",
          "regex": "sut\\.load\\(\\)\\s*// request A.*sut\\.load\\(\\)\\s*// request B",
          "dotall": true
        },
        {
          "label": "Asserts latest result wins",
          "regex": "XCTAssertEqual\\(sut\\.state\\.items\\.map\\(\\\\\\.title\\),\\s*\\[\\\"latest\\\"\\]\\)"
        },
        {
          "label": "Has cancellation or stale-focused test",
          "regex": "(?m)func\\s+test\\w*(cancel|stale)\\w+"
        }
      ]
    },
